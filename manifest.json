{
  "manifest_version": 3,
  "name": "Deepfake Image Detector",
  "version": "1.0.0",
  "icons": { "128": "icon.png" },
  "description": "Detect whether an image is real or AI-generated (deepfake) using a local backend.",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:5000/*", "http://127.0.0.1:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Deepfake Image Detector"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
